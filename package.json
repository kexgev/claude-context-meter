{
  "name": "claude-context-meter",
  "displayName": "Claude Context Meter",
  "description": "Instant token usage meter for Claude Code — ASCII progress bar, live file-watcher updates, no polling",
  "version": "1.0.0",
  "publisher": "asjalik",
  "repository": { "type": "git", "url": "https://github.com/asjalik/claude-context-bar" },
  "engines": { "vscode": "^1.74.0" },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/src/extension.js",
  "icon": "media/icon.png",
  "contributes": {
    "configuration": {
      "title": "Claude Context Bar",
      "properties": {
        "claudeContextBar.contextLimit": {
          "type": "number", "default": 200000, "minimum": 1000, "maximum": 2000000,
          "description": "Fallback token limit when model is not detected"
        },
        "claudeContextBar.idleTimeout": {
          "type": "number", "default": 180, "minimum": 10, "maximum": 600,
          "description": "Seconds of inactivity before hiding a session"
        },
        "claudeContextBar.warningThreshold": {
          "type": "number", "default": 50, "minimum": 1, "maximum": 99,
          "description": "Percentage at which status bar turns yellow"
        },
        "claudeContextBar.dangerThreshold": {
          "type": "number", "default": 75, "minimum": 2, "maximum": 100,
          "description": "Percentage at which status bar turns red"
        },
        "claudeContextBar.compactMode": {
          "type": "boolean", "default": false,
          "description": "Abbreviate project names in status bar"
        },
        "claudeContextBar.showEmoji": {
          "type": "boolean", "default": true,
          "description": "Show project emoji in status bar"
        },
        "claudeContextBar.autoColor": {
          "type": "boolean", "default": true,
          "description": "Auto-assign pastel colors per project"
        },
        "claudeContextBar.shortNames": {
          "type": "object", "default": {},
          "description": "Custom name overrides: { \"projectName\": \"abbr\" }"
        }
      }
    },
    "commands": [
      {
        "command": "claudeContextBar.hideSession",
        "title": "Hide Claude Session",
        "category": "Claude Context Bar"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p tsconfig.json",
    "watch": "tsc -p tsconfig.json --watch",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTests.js",
    "lint": "eslint src --ext .ts",
    "vsce:package": "vsce package"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.0",
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/test-electron": "^2.3.0",
    "eslint": "^8.0.0",
    "mocha": "^10.0.0",
    "typescript": "^5.0.0",
    "@vscode/vsce": "^2.0.0"
  },
  "dependencies": {}
}
